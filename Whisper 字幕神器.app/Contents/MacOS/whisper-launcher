#!/bin/zsh
set -u

APP_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$APP_ROOT"

# 檢查是否遭到 macOS App Translocation (隔離機制) 導致找不到 app.py
if [ ! -f "$APP_ROOT/app.py" ]; then
  /usr/bin/osascript -e 'display dialog "找不到 app.py！\n\n這通常是因為 macOS 的安全機制（App Translocation）將啟動程式隔離了。請開啟「終端機」，輸入以下指令解除隔離：\n\nxattr -cr \"'"$APP_ROOT"'\"" buttons {"了解"} default button "了解" with title "啟動失敗" with icon stop' >/dev/null 2>&1
  exit 1
fi

# 檢查目錄是否有寫入權限 (建立 log 與 venv 需要)
if [ ! -w "$APP_ROOT" ]; then
  /usr/bin/osascript -e 'display dialog "目前資料夾沒有寫入權限！\n\n請將整個 Whisper 字幕神器資料夾移動到「應用程式」或「桌面」再試一次；或是使用 xattr -cr 解除隔離。" buttons {"了解"} default button "了解" with title "權限錯誤" with icon stop' >/dev/null 2>&1
  exit 1
fi

LOG_DIR="$APP_ROOT/logs"
LOG_FILE="$LOG_DIR/macos-app.log"
mkdir -p "$LOG_DIR" || {
  /usr/bin/osascript -e 'display dialog "無法建立 logs 資料夾，請檢查權限。" buttons {"OK"} default button "OK" with title "錯誤" with icon stop' >/dev/null 2>&1
  exit 1
}
exec >> "$LOG_FILE" 2>&1

echo "================================"
echo "Whisper 字幕神器 .app launch $(date)"
echo "Project: $APP_ROOT"
echo "================================"

export PATH="/opt/homebrew/bin:/usr/local/bin:/opt/local/bin:${PATH}"
export PYTORCH_ENABLE_MPS_FALLBACK="${PYTORCH_ENABLE_MPS_FALLBACK:-1}"

# 修正 Homebrew Python 3.12 的 pyexpat / libexpat 相容性問題 (Apple Silicon 與 Intel)
if command -v brew >/dev/null 2>&1; then
  EXPAT_LIB="$(brew --prefix expat 2>/dev/null)/lib"
  if [ ! -d "$EXPAT_LIB" ]; then
    echo "[SETUP] Missing expat for Python. Installing via Homebrew..."
    brew install expat >/dev/null 2>&1 || true
    EXPAT_LIB="$(brew --prefix expat 2>/dev/null)/lib"
  fi
  if [ -d "$EXPAT_LIB" ]; then
    export DYLD_LIBRARY_PATH="$EXPAT_LIB:${DYLD_LIBRARY_PATH:-}"
  fi
fi

notify_error() {
  /usr/bin/osascript -e 'display dialog "Whisper 字幕神器啟動失敗，請查看 logs/macos-app.log。" buttons {"OK"} default button "OK" with title "Whisper 字幕神器" with icon caution' >/dev/null 2>&1 || true
}

notify_started() {
  /usr/bin/osascript -e 'display notification "已在背景啟動，瀏覽器即將開啟。" with title "Whisper 字幕神器"' >/dev/null 2>&1 || true
}

notify_ffmpeg_missing() {
  /usr/bin/osascript -e 'display notification "尚未找到 ffmpeg，轉錄音訊/影片前請先安裝：brew install ffmpeg。" with title "Whisper 字幕神器"' >/dev/null 2>&1 || true
}

pick_port() {
  local first_port="${WHISPER_PORT:-5050}"
  local ports=("$first_port" 5050 5051 5052 5053 5054 5055 5056 5057 5058 5059)
  local seen=""

  for port in "${ports[@]}"; do
    [[ " $seen " == *" $port "* ]] && continue
    seen="$seen $port"

    local pids
    pids=$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)
    if [ -z "$pids" ]; then
      echo "$port"
      return 0
    fi

    for pid in ${(f)pids}; do
      local cmd
      cmd=$(ps -p "$pid" -o command= 2>/dev/null || true)
      if [[ "$cmd" == *"app.py"* ]]; then
        echo "$port"
        return 0
      fi
    done
  done

  return 1
}

PORT="$(pick_port)" || {
  echo "[ERROR] No free port found from 5050 to 5059."
  notify_error
  exit 1
}
export WHISPER_PORT="$PORT"
URL="http://localhost:${PORT}"

PIDS=$(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)
if [ -n "$PIDS" ]; then
  for PID in ${(f)PIDS}; do
    CMD=$(ps -p "$PID" -o command= 2>/dev/null || true)
    if [[ "$CMD" == *"app.py"* ]]; then
      echo "[INFO] Whisper server already running on $URL"
      open "$URL"
      exit 0
    fi
  done
fi

BASE_PYTHON=""
if [ -x ".venv/bin/python" ]; then
  PYTHON="$PWD/.venv/bin/python"
  echo "[OK] Project virtual environment found"
else
  for CANDIDATE in python3.12 python3.11 python3.10 python3.9 python3; do
    if command -v "$CANDIDATE" >/dev/null 2>&1; then
      if "$CANDIDATE" -c "import sys; sys.exit(0 if sys.version_info >= (3, 9) else 1)" >/dev/null 2>&1; then
        BASE_PYTHON="$CANDIDATE"
        break
      fi
    fi
  done

  if [ -z "$BASE_PYTHON" ]; then
    echo "[ERROR] No compatible Python 3.9+ found."
    notify_error
    exit 1
  fi

  echo "[SETUP] Creating .venv with ${BASE_PYTHON}..."
  "$BASE_PYTHON" -m venv --clear .venv 2>/dev/null || "$BASE_PYTHON" -m venv --without-pip --clear .venv || {
    echo "[ERROR] Failed to create .venv."
    /usr/bin/osascript -e 'display dialog "無法建立 Python 虛擬環境！\n\n這通常是因為權限問題（例如放在 iCloud 同步的桌面/文件，或是外接硬碟）。\n\n請嘗試將整個「Whisper-Subtitle」資料夾移動到「使用者家目錄」或是「應用程式」內，再重新啟動。" buttons {"了解"} default button "了解" with title "建立環境失敗" with icon stop' >/dev/null 2>&1
    exit 1
  }
  PYTHON="$PWD/.venv/bin/python"
fi

if ! "$PYTHON" -m pip --version >/dev/null 2>&1; then
  echo "[SETUP] Enabling pip..."
  "$PYTHON" -m ensurepip --upgrade 2>/dev/null || {
    echo "[SETUP] ensurepip failed, trying get-pip.py..."
    curl -sS https://bootstrap.pypa.io/get-pip.py -o /tmp/_get_pip.py && "$PYTHON" /tmp/_get_pip.py 2>&1 || {
      echo "[ERROR] Failed to enable pip."
      /usr/bin/osascript -e 'display dialog "Python 環境啟動失敗 (pip error)！\n\n如果錯誤紀錄顯示 `pyexpat` 或 `libexpat` 相關錯誤，這是因為您的 Homebrew 套件版本衝突。\n\n請打開終端機，執行以下指令修復您的系統 Python：\n\nbrew upgrade expat python@3.12" buttons {"了解"} default button "了解" with title "系統套件衝突" with icon stop' >/dev/null 2>&1
      exit 1
    }
  }
fi

if ! "$PYTHON" -c "import flask, whisper" >/dev/null 2>&1; then
  echo "[INSTALL] Installing requirements.txt..."
  "$PYTHON" -m pip install -r requirements.txt || {
    echo "[ERROR] Package install failed."
    notify_error
    exit 1
  }
fi

if command -v ffmpeg >/dev/null 2>&1; then
  echo "[OK] ffmpeg found: $(command -v ffmpeg)"
else
  echo "[WARN] ffmpeg was not found. Install with Homebrew: brew install ffmpeg"
  notify_ffmpeg_missing
fi

echo "[START] Starting server at $URL"
nohup "$PYTHON" app.py >> "$LOG_FILE" 2>&1 &
SERVER_PID=$!
echo "[START] PID $SERVER_PID"

for _ in {1..60}; do
  if "$PYTHON" -c "import urllib.request; urllib.request.urlopen('$URL', timeout=1).read(1)" >/dev/null 2>&1; then
    notify_started
    open "$URL"
    exit 0
  fi

  if ! kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    echo "[ERROR] Server process stopped before becoming ready."
    notify_error
    exit 1
  fi

  sleep 1
done

echo "[ERROR] Server did not become ready within 60 seconds."
notify_error
exit 1
