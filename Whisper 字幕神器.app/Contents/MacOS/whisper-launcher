#!/bin/zsh
set -u

APP_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$APP_ROOT"

# --- 環境與權限統一預檢 (Pre-flight Check) ---
MISSING_ENV=""
IS_FATAL=0

# 1. 隔離檢測 (App Translocation)
if [ ! -f "$APP_ROOT/app.py" ]; then
  MISSING_ENV="${MISSING_ENV}- 程式遭到 macOS 隔離，請使用 xattr -cr 解除限制\n"
  IS_FATAL=1
fi

# 2. 權限檢測 (iCloud/唯讀目錄)
if [ ! -w "$APP_ROOT" ]; then
  MISSING_ENV="${MISSING_ENV}- 所在資料夾沒有寫入權限，請將整個資料夾移動到「家目錄」或「應用程式」內\n"
  IS_FATAL=1
fi

# 3. 檢查 Python
BASE_PYTHON=""
for CANDIDATE in python3.12 python3.11 python3.10 python3.9 python3; do
  if command -v "$CANDIDATE" >/dev/null 2>&1; then
    if "$CANDIDATE" -c "import sys; sys.exit(0 if sys.version_info >= (3, 9) else 1)" >/dev/null 2>&1; then
      BASE_PYTHON="$CANDIDATE"
      break
    fi
  fi
done

if [ -z "$BASE_PYTHON" ]; then
  MISSING_ENV="${MISSING_ENV}- 找不到 Python 3.9 以上版本\n"
  IS_FATAL=1
fi

# 4. 檢查 ffmpeg
if ! command -v ffmpeg >/dev/null 2>&1; then
  MISSING_ENV="${MISSING_ENV}- 找不到 ffmpeg 影音處理套件\n"
  IS_FATAL=1
fi

# 5. 若有缺失，統一跳出引導視窗並終止
if [ $IS_FATAL -eq 1 ]; then
  /usr/bin/osascript -e '
    set dialogText to "【啟動失敗：環境或權限不符】\n\n啟動 Whisper 字幕神器前，偵測到以下問題：\n\n'"$MISSING_ENV"'\n👉 解決方式：\n點擊下方按鈕查看詳細的排錯與安裝教學。請確保環境與權限正確後再重新啟動！"
    set response to display dialog dialogText buttons {"離開", "查看教學與常見問題"} default button "查看教學與常見問題" with title "Whisper 字幕神器" with icon stop
    if button returned of response is "查看教學與常見問題" then
      open location "https://github.com/hsuliang/whisper/releases/tag/v1.0.0"
    end if
  ' >/dev/null 2>&1
  exit 1
fi

LOG_DIR="$APP_ROOT/logs"
LOG_FILE="$LOG_DIR/macos-app.log"
mkdir -p "$LOG_DIR" || exit 1
exec >> "$LOG_FILE" 2>&1

echo "================================"
echo "Whisper 字幕神器 .app launch $(date)"
echo "Project: $APP_ROOT"
echo "================================"

export PATH="/opt/homebrew/bin:/usr/local/bin:/opt/local/bin:${PATH}"
export PYTORCH_ENABLE_MPS_FALLBACK="${PYTORCH_ENABLE_MPS_FALLBACK:-1}"

# 自動處理 Homebrew Python 的 expat 問題 (若缺漏則於背景靜默安裝)
if command -v brew >/dev/null 2>&1; then
  EXPAT_PREFIX="$(brew --prefix expat 2>/dev/null)"
  if [ -z "$EXPAT_PREFIX" ] || [ ! -d "$EXPAT_PREFIX/lib" ]; then
    echo "[SETUP] Missing expat for Python. Installing via Homebrew..."
    brew install expat >/dev/null 2>&1 || true
    EXPAT_PREFIX="$(brew --prefix expat 2>/dev/null)"
  fi
  if [ -n "$EXPAT_PREFIX" ] && [ -d "$EXPAT_PREFIX/lib" ]; then
    export DYLD_LIBRARY_PATH="$EXPAT_PREFIX/lib:${DYLD_LIBRARY_PATH:-}"
  fi
fi

notify_error() {
  /usr/bin/osascript -e 'display dialog "Whisper 字幕神器啟動失敗，請查看 logs/macos-app.log 以獲取更多資訊。" buttons {"OK"} default button "OK" with title "Whisper 字幕神器" with icon caution' >/dev/null 2>&1 || true
}

notify_started() {
  /usr/bin/osascript -e 'display notification "已在背景啟動，瀏覽器即將開啟。" with title "Whisper 字幕神器"' >/dev/null 2>&1 || true
}

pick_port() {
  local first_port="${WHISPER_PORT:-5050}"
  local ports=("$first_port" 5050 5051 5052 5053 5054 5055 5056 5057 5058 5059)
  local seen=""

  for port in "${ports[@]}"; do
    [[ " $seen " == *" $port "* ]] && continue
    seen="$seen $port"

    local pids
    pids=$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)
    if [ -z "$pids" ]; then
      echo "$port"
      return 0
    fi

    for pid in ${(f)pids}; do
      local cmd
      cmd=$(ps -p "$pid" -o command= 2>/dev/null || true)
      if [[ "$cmd" == *"app.py"* ]]; then
        echo "$port"
        return 0
      fi
    done
  done

  return 1
}

PORT="$(pick_port)" || {
  echo "[ERROR] No free port found from 5050 to 5059."
  notify_error
  exit 1
}
export WHISPER_PORT="$PORT"
URL="http://localhost:${PORT}"

PIDS=$(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)
if [ -n "$PIDS" ]; then
  for PID in ${(f)PIDS}; do
    CMD=$(ps -p "$PID" -o command= 2>/dev/null || true)
    if [[ "$CMD" == *"app.py"* ]]; then
      echo "[INFO] Whisper server already running on $URL"
      open "$URL"
      exit 0
    fi
  done
fi

# 如果是首次安裝 (無 .venv) 或是尚未啟動，彈出進度網頁
if [ ! -d "$APP_ROOT/.venv" ] || ! curl -s "$URL" >/dev/null 2>&1; then
  echo "[INFO] Opening loading screen..."
  open "file://$APP_ROOT/loading.html?port=$PORT"
fi

if [ -x ".venv/bin/python" ]; then
  PYTHON="$PWD/.venv/bin/python"
  echo "[OK] Project virtual environment found"
else
  echo "[SETUP] Creating .venv with ${BASE_PYTHON}..."
  "$BASE_PYTHON" -m venv --clear .venv 2>/dev/null || "$BASE_PYTHON" -m venv --without-pip --clear .venv || {
    echo "[ERROR] Failed to create .venv."
    notify_error
    exit 1
  }
  PYTHON="$PWD/.venv/bin/python"
fi

if ! "$PYTHON" -m pip --version >/dev/null 2>&1; then
  echo "[SETUP] Enabling pip..."
  "$PYTHON" -m ensurepip --upgrade 2>/dev/null || {
    echo "[SETUP] ensurepip failed, trying get-pip.py..."
    curl -sS https://bootstrap.pypa.io/get-pip.py -o /tmp/_get_pip.py && "$PYTHON" /tmp/_get_pip.py 2>&1 || {
      echo "[ERROR] Failed to enable pip."
      notify_error
      exit 1
    }
  }
fi

if ! "$PYTHON" -c "import flask, whisper" >/dev/null 2>&1; then
  echo "[INSTALL] Installing requirements.txt..."
  "$PYTHON" -m pip install -r requirements.txt || {
    echo "[ERROR] Package install failed."
    notify_error
    exit 1
  }
fi

echo "[START] Starting server at $URL"
nohup "$PYTHON" app.py >> "$LOG_FILE" 2>&1 &
SERVER_PID=$!
echo "[START] PID $SERVER_PID"

for _ in {1..60}; do
  if "$PYTHON" -c "import urllib.request; urllib.request.urlopen('$URL', timeout=1).read(1)" >/dev/null 2>&1; then
    notify_started
    open "$URL"
    exit 0
  fi

  if ! kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    echo "[ERROR] Server process stopped before becoming ready."
    notify_error
    exit 1
  fi

  sleep 1
done

echo "[ERROR] Server did not become ready within 60 seconds."
notify_error
exit 1
